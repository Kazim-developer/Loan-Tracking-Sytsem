// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique

  accounts  Account[]
  passwordRestTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String

  name      String?
  imageUrl  String?

  provider          String
  providerAccountId String
  passwordHash      String?
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?

  clients Client[]
  loans Loan[]
  sessions Session[]

  subscription  Subscription?
  usage Usage?
  subscriptionAddOn SubscriptionAddOn[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}


model Session {
  id           String   @id @default(uuid())

  accountId String
  sessionToken String   @unique
  createdAt DateTime @default(now())
  expiresAt    DateTime

  account Account @relation(fields:[accountId], references:[id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id        String   @id @default(uuid())
  accountId String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?

  loans Loan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields:[accountId], references:[id], onDelete: Cascade)

  @@index([accountId])
  @@unique([accountId, email])
}

model Loan {
  id                String   @id @default(uuid())

  accountId String
  account Account @relation(fields:[accountId], references:[id], onDelete: Cascade)

  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete:Cascade)

  totalAmount       Float
  totalPayable Float
  
  interestRate      Float?   
  interestType      InterestType? 

  startingDate         DateTime
  endDate DateTime?

  status LoanStatus @default(ACTIVE)
  repaymentStatus RepaymentStatus @default(PENDING)
  
  hasInstallments   Boolean  @default(false)
  totalInstallments  Int?
  installmentAmount Float?   
  installmentFrequency         Frequency?
  firstInstallmentDate  DateTime?
  lastInstallmentDate DateTime?

  installments      LoanInstallment[]
  loanPayments          LoanPayment[]
  loanReminders Reminder[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([accountId])

  @@index([accountId, status])

  @@index([accountId, repaymentStatus])

  @@index([accountId, createdAt])
}

model LoanInstallment {
  id           String   @id @default(uuid())

  loanId       String
  loan         Loan     @relation(fields: [loanId], references: [id], onDelete:Cascade)

  dueDate      DateTime
  amount       Float

  status       InstallmentStatus @default(PENDING)

  paidAt      DateTime?

  installmentReminders Reminder[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([loanId])
  @@index([loanId, status])
  @@index([loanId, dueDate])
}

model LoanPayment {
  id        String   @id @default(uuid())

  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete:Cascade)

  amount    Float
  paidAt      DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([loanId])
  @@index([loanId, paidAt])
}


enum InterestType {
  SIMPLE
  COMPOUND
}

enum Frequency {
  WEEKLY
  MONTHLY
}

enum LoanStatus{
  ACTIVE
  CLOSED
}

enum RepaymentStatus {
  PENDING
  PARTIAL
  PAID
  DUE
  OVERDUE
}

enum InstallmentStatus {
  PENDING
  PAID
  DUE
  OVERDUE
}

model Reminder {
  id              String   @id @default(uuid())

  installmentId   String?
  installment     LoanInstallment? @relation(fields: [installmentId], references: [id])

  loanId String?
  loan Loan? @relation(fields:[loanId], references:[id])

  reminderDate    DateTime
  sent            Boolean  @default(false)

  type            ReminderType

  createdAt       DateTime @default(now())
}

enum ReminderType {
  EMAIL
  WHATSAPP
}


model Plan {
  id                 String   @id @default(uuid())
  name               String   @unique
  description        String?

  priceMonth         Int      
  priceYear          Int?

  monthlyPriceId String? @unique

  maxClients Int?
  maxActiveLoans        Int?
  maxTotalLoans Int?
  maxTeamMembers     Int?

  maxEmailReminders  Int?
  maxWhatsappReminders Int?

  features  PlanFeature[]

  isActive           Boolean  @default(true)

  subscriptions      Subscription[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PlanFeature {
  id      String @id @default(uuid())
  planId  String
  key     String
  enabled Boolean

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@index([key])
}

model Subscription {
  id        String   @id @default(uuid())
  accountId String   @unique  
  planId    String

  status       SubscriptionStatus
  billingCycle BillingCycle
  autoRenew    Boolean @default(true)

  startDate DateTime
  endDate   DateTime?
  cancelAt  DateTime?

  provider                String @default("paddle")
  providerSubscriptionId  String? @unique
  providerCustomerId      String?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
  @@index([accountId])
  @@index([providerCustomerId])
}

model SubscriptionAddOn{
  id String @id @default(uuid())

  accountId String

  type AddOnType
  quantity Int
  used Int @default(0)

  paddleTransactionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields:[accountId], references:[id], onDelete:Cascade)

  @@index([accountId])
}

model WebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType        String
  processedAt DateTime @default(now())

  createdAt   DateTime @default(now())
}

model Usage{
  id String @id @default(uuid())

  accountId String @unique

  billingPeriodStart DateTime
  billingPeriodEnd DateTime

  usedClients Int @default(0)
  usedActiveLoans Int @default(0)
  usedTotalLoans Int @default(0)
  usedEmailReminders Int @default(0)

  account Account @relation(fields:[accountId], references:[id], onDelete:Cascade)

  @@index([accountId])
}

enum AddOnType {
  EMAIL_REMINDERS
  WHATSAPP_REMINDERS
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  PAST_DUE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}